// Shared Sparkle 1.27 updater host (mavericks-shared-cmake template; configured per product via @MAVERICKS_*@).
// A tiny normal ObjC/ARC app that runs an on-demand or scheduled (--background) update check. Two
// background-found-update modes (see MAVERICKS_PANE_HINT_KEY): pane-hint (a host UI surfaces it) or user
// notification (no pane; click -> foreground install).
//
// We DON'T #import <Sparkle/Sparkle.h> — Sparkle 1.27's headers use nullability/generics that the
// 10.9-era clang 6.0 can't parse. ObjC dispatch is runtime, so we declare the SUUpdater slice we use
// ourselves (below) and link the real framework binary. Same source builds on clang 6.0 (dev) and
// modern clang (CI). Delegate = informal protocol (respondsToSelector:).
#import <Cocoa/Cocoa.h>

@interface SUUpdater : NSObject
+ (SUUpdater *)sharedUpdater;
- (void)checkForUpdates:(id)sender;                 // user-initiated: always shows UI
- (void)checkForUpdateInformation;                  // scheduled: PROBING check -> calls delegates, NO UI ever
- (void)setDelegate:(id)delegate;
@end

// The appcast item Sparkle hands to -updater:didFindValidUpdate:. We only read its display version.
@interface SUAppcastItem : NSObject
- (NSString *)displayVersionString;
@end

// Product seam for "an update was found in the background". PANE_HINT_KEY set => record the available
// version under this app's own defaults domain, for a host UI (e.g. trackpad2's prefpane About tab) to
// surface. Empty => no pane; instead post a user notification whose click re-launches this app foreground
// to install (e.g. mavericks-swift, a headless runtime with no pane).
#define MAVERICKS_PANE_HINT_KEY "@MAVERICKS_PANE_HINT_KEY@"
static NSString *const kAvailableUpdateKey = @"@MAVERICKS_PANE_HINT_KEY@";

// UI is OPT-IN. Only an EXPLICIT user summon shows anything: `--user` (a notification
// "install" click) runs Sparkle's interactive check -- the ONLY path that shows a "You're up-to-date!"
// or update dialog. EVERY other launch (`--background` daily agent, or no flag at all) runs a SILENT
// probe: no dialog, exit when done. That keeps un-summoned / scheduled checks completely quiet -- a
// found update is surfaced via a notification (no-pane) or the pane hint, never a modal.
static BOOL gBackground = NO;      // --background: the scheduled LaunchAgent (honors the auto-check pref)
static BOOL gUserInitiated = NO;   // --user: an explicit summon (notification "install" click, or launching the .app)

// Background-check watchdog. Sparkle's silent background check can hang before calling ANY delegate
// (a network/appcast stall) -> no dialog, no exit, the helper lingers in the Dock forever (observed
// 2026-07-07, "no dialog, wouldn't quit"). In --background mode we arm this timer at check-start and
// CANCEL it the instant either delegate fires (found/not-found); if neither does, Sparkle hung, so we
// force-exit. Cancel-on-resolution means it can NEVER kill a legit update dialog or an in-progress
// install (those already called a delegate). Foreground (manual) checks are untouched.
static const NSTimeInterval kBackgroundWatchdogSeconds = 120.0;
static NSTimer *gWatchdog = nil;

// Sparkle 1.x relaunches the host after a .pkg install and there is no config to suppress it. We drop
// a marker just before relaunch so the relaunched instance exits quietly instead of re-checking.
static NSString *const kRelaunchMarker = @"@MAVERICKS_RELAUNCH_MARKER@";

@interface MavericksUpdaterDelegate : NSObject   // informal SUUpdaterDelegate (invoked via respondsToSelector:)
@end
@implementation MavericksUpdaterDelegate
- (void)updaterWillRelaunchApplication:(SUUpdater *)updater {
    (void)updater;
    [[NSData data] writeToFile:kRelaunchMarker atomically:YES];
}
- (void)terminateNow { NSLog(@"[@MAVERICKS_LOG_PREFIX@] terminating"); [NSApp terminate:nil]; }
- (void)cancelWatchdog { [gWatchdog invalidate]; gWatchdog = nil; }
- (void)watchdogFired:(NSTimer *)t {
    (void)t; gWatchdog = nil;
    NSLog(@"[@MAVERICKS_LOG_PREFIX@] watchdog: background check didn't resolve in %.0fs, forcing exit", kBackgroundWatchdogSeconds);
    [NSApp terminate:nil];
}
- (void)updater:(SUUpdater *)updater didFindValidUpdate:(SUAppcastItem *)item {
    (void)updater;
    NSString *v = [item respondsToSelector:@selector(displayVersionString)] ? [item displayVersionString] : nil;
    if (strlen(MAVERICKS_PANE_HINT_KEY) > 0) {
        // Pane-hint mode (trackpad2): record the available version for a host UI (About tab) to surface.
        if (v.length) {
            [[NSUserDefaults standardUserDefaults] setObject:v forKey:kAvailableUpdateKey];
            [[NSUserDefaults standardUserDefaults] synchronize];
        }
        if (!gUserInitiated) {
            // Silent probe -> no dialog; hint recorded; exit immediately (never leave a blocking dialog).
            [self cancelWatchdog];
            NSLog(@"[@MAVERICKS_LOG_PREFIX@] update available: %@ — recorded pane hint; silent probe -> exit", v.length ? v : @"(unknown)");
            [NSApp terminate:nil];
            return;
        }
        NSLog(@"[@MAVERICKS_LOG_PREFIX@] update available: %@ — foreground: presenting update dialog", v.length ? v : @"(unknown)");
        return;
    }
    // No-pane mode (mavericks-swift): a non-interactive find must surface SOMETHING actionable.
    if (!gUserInitiated) {
        // Post a user notification (click -> foreground install), then exit. Delay the exit briefly so
        // the notification flushes to the daemon before we terminate.
        [self cancelWatchdog];
        NSUserNotification *n = [[NSUserNotification alloc] init];
        n.title = [NSString stringWithFormat:@"%@ update available", @"@MAVERICKS_PRODUCT_NAME@"];
        n.informativeText = v.length ? [NSString stringWithFormat:@"Version %@ is ready. Click to install.", v]
                                     : @"An update is ready. Click to install.";
        n.hasActionButton = YES; n.actionButtonTitle = @"Install";
        [[NSUserNotificationCenter defaultUserNotificationCenter] deliverNotification:n];
        NSLog(@"[@MAVERICKS_LOG_PREFIX@] update available: %@ — posted notification; background -> exit", v.length ? v : @"(unknown)");
        [self performSelector:@selector(terminateNow) withObject:nil afterDelay:3.0 inModes:@[NSDefaultRunLoopMode]];
        return;
    }
    // Foreground (manual): let Sparkle present its normal update dialog.
    NSLog(@"[@MAVERICKS_LOG_PREFIX@] update available: %@ — foreground: presenting update dialog", v.length ? v : @"(unknown)");
}
- (void)updaterDidNotFindUpdate:(SUUpdater *)updater {
    (void)updater;
    [self cancelWatchdog];   // check resolved (no update) -> we exit on our own below
    // Up to date -> clear any stale "update available" hint the pane might be showing.
    [[NSUserDefaults standardUserDefaults] removeObjectForKey:kAvailableUpdateKey];
    [[NSUserDefaults standardUserDefaults] synchronize];
    // Background (scheduled) mode shows no alert -> nothing to wait for; exit right away so the
    // LSUIElement process never lingers.
    if (!gUserInitiated) { NSLog(@"[@MAVERICKS_LOG_PREFIX@] no update; not user-initiated -> terminating silently"); [NSApp terminate:nil]; return; }
    NSLog(@"[@MAVERICKS_LOG_PREFIX@] no update; user-initiated -> terminate after the up-to-date alert is dismissed");
    // Sparkle 1.27 calls this delegate BEFORE it shows its modal "You're up-to-date!" alert
    // (SUUIBasedUpdateDriver -didNotFindUpdate: delegate first, then a blocking -runModal). Calling
    // [NSApp terminate:] here killed the app before that alert could appear -- so a manual check
    // silently did nothing visible.
    //
    // We must let the alert show and still exit cleanly (LSUIElement, no window -> can't linger).
    // The alert runs a nested modal run loop in NSModalPanelRunLoopMode; schedule the terminate as a
    // zero-delay timer registered ONLY in NSDefaultRunLoopMode. It cannot fire during the modal loop
    // (wrong mode), and this call stack never returns to the default loop until after the alert is
    // dismissed -- so termination happens exactly once the user closes the alert. No window/notification
    // guessing, deterministic ordering.
    [self performSelector:@selector(terminateNow)
               withObject:nil
               afterDelay:0.0
                  inModes:@[NSDefaultRunLoopMode]];
}
- (void)userDidCancelDownload:(SUUpdater *)updater   { (void)updater; NSLog(@"[@MAVERICKS_LOG_PREFIX@] download cancelled -> terminating"); [NSApp terminate:nil]; }
// NSUserNotificationCenter delegate (no-pane mode). Force the banner to show even if we're frontmost,
// and on click re-launch ourselves foreground (no --background) to run Sparkle's install UI.
- (BOOL)userNotificationCenter:(NSUserNotificationCenter *)c
     shouldPresentNotification:(NSUserNotification *)n { (void)c; (void)n; return YES; }
- (void)userNotificationCenter:(NSUserNotificationCenter *)c
       didActivateNotification:(NSUserNotification *)n {
    (void)c; (void)n;
    NSString *me = [[NSBundle mainBundle] executablePath];
    if (me) [NSTask launchedTaskWithLaunchPath:me arguments:@[@"--user"]];   // clicked "Install" -> interactive
    [NSApp terminate:nil];
}
@end

static MavericksUpdaterDelegate *gDelegate;  // strong; SUUpdater.delegate is unretained in 1.x

int main(int argc, const char **argv) {
    for (int i = 1; i < argc; i++) {
        if (strcmp(argv[i], "--background") == 0) gBackground = YES;
        else if (strcmp(argv[i], "--user") == 0)  gUserInitiated = YES;
    }
    @autoreleasepool {
        [NSApplication sharedApplication];
        [NSApp setActivationPolicy:NSApplicationActivationPolicyRegular];  /* normal foreground app (see Info.plist) */

        NSString *selfVersion = [[NSBundle mainBundle] objectForInfoDictionaryKey:@"CFBundleShortVersionString"];
        NSLog(@"[@MAVERICKS_LOG_PREFIX@] start: mode=%@ version=%@",
              gUserInitiated ? @"user" : (gBackground ? @"background" : @"silent"),
              selfVersion.length ? selfVersion : @"(unknown)");

        // Sparkle relaunched us after a successful install (it dropped a marker in
        // updaterWillRelaunchApplication:). Show one "you're updated" confirmation, since the update
        // changed the kext/daemon/pane, not this helper, so there's otherwise NO visible signal.
        // ROBUSTNESS: ALWAYS remove the marker, and only honor it if it's FRESH — a stale marker left by an
        // interrupted/killed flow otherwise made EVERY later launch pop a bogus "updated" dialog and skip
        // the check (it once showed "updated to 0.4.0" when nothing had installed). Read the ACTUAL
        // installed version: the pkg replaced this app too, so our own bundle version IS the new version.
        NSFileManager *fm = [NSFileManager defaultManager];
        if ([fm fileExistsAtPath:kRelaunchMarker]) {
            NSDate *stamp = [[fm attributesOfItemAtPath:kRelaunchMarker error:NULL] fileModificationDate];
            BOOL fresh = stamp && [[NSDate date] timeIntervalSinceDate:stamp] < 300.0;
            if (gBackground) {
                // A fresh marker means an update JUST installed. The postinstall reloads the
                // daily-check LaunchAgent, whose RunAtLoad fires a background instance mid-install --
                // don't run a redundant check right after an install, and DON'T consume the marker:
                // leave it so Sparkle's FOREGROUND relaunch shows the single "updated" confirmation
                // (whichever races first must not steal it). Only a STALE marker is cleared here.
                if (fresh) {
                    NSLog(@"[@MAVERICKS_LOG_PREFIX@] fresh post-install marker; background -> exit (no check, marker kept)");
                    return 0;
                }
                [fm removeItemAtPath:kRelaunchMarker error:NULL];   // stale -> clear, fall through to a check
            } else {
                [fm removeItemAtPath:kRelaunchMarker error:NULL];   // foreground consumes the marker
                if (fresh) {
                    // The update changed the kext/daemon/pane, not this helper, so there's otherwise NO
                    // visible signal -- show one confirmation. Our own (just-replaced) bundle version IS
                    // the new version. Freshness gate stops a stale marker from popping a bogus dialog.
                    NSLog(@"[@MAVERICKS_LOG_PREFIX@] post-install relaunch; showing 'updated to %@' confirmation",
                          selfVersion.length ? selfVersion : @"(unknown)");
                    [NSApp activateIgnoringOtherApps:YES];
                    NSAlert *done = [[NSAlert alloc] init];
                    [done setMessageText:@"@MAVERICKS_CONFIRM_TITLE@"];
                    [done setInformativeText:@"@MAVERICKS_CONFIRM_BODY@"];
                    [done addButtonWithTitle:@"OK"];
                    [done runModal];
                    // Product post-update hook: run an optional helper (as the user, in this GUI session)
                    // for product-specific follow-up after an install -- e.g. offer to roll a running VM
                    // onto the freshly-installed image. Empty path -> no-op. Fire-and-forget; it owns its UI.
                    NSString *postHelper = @"@MAVERICKS_POST_UPDATE_HELPER@";
                    if (postHelper.length && [[NSFileManager defaultManager] isExecutableFileAtPath:postHelper]) {
                        NSLog(@"[@MAVERICKS_LOG_PREFIX@] running post-update helper: %@", postHelper);
                        @try { NSTask *t = [NSTask new]; t.launchPath = postHelper; [t launch]; }
                        @catch (NSException *e) { NSLog(@"[@MAVERICKS_LOG_PREFIX@] post-update helper failed: %@", e); }
                    }
                    return 0;
                }
                // stale foreground marker -> fall through to a normal check
            }
        }

        // Auto-update policy. Pre-seed SUEnableAutomaticChecks the first time (if never set) so Sparkle 1.x
        // doesn't pop its own "check automatically?" prompt, and so `defaults read` reflects the shipped
        // default. Product seam: trackpad2 defaults OFF (discoverable prefpane owns the toggle);
        // mavericks-swift defaults ON (headless runtime, no pane -> the daily agent is the only path).
        NSUserDefaults *ud = [NSUserDefaults standardUserDefaults];
        if ([ud objectForKey:@"SUEnableAutomaticChecks"] == nil) [ud setBool:@MAVERICKS_AUTO_CHECK_OBJC@ forKey:@"SUEnableAutomaticChecks"];

        // Background (daily LaunchAgent) mode HONORS that checkbox: the probe runs regardless of the
        // setting, so gate it ourselves — auto-checks OFF means the daily agent does nothing.
        // (A user-initiated check is never gated.)
        if (gBackground && ![ud boolForKey:@"SUEnableAutomaticChecks"]) {
            NSLog(@"[@MAVERICKS_LOG_PREFIX@] background: auto-check disabled -> exiting");
            return 0;
        }

        [NSApp activateIgnoringOtherApps:YES];                 // LSUIElement: bring Sparkle's dialog forward
        gDelegate = [[MavericksUpdaterDelegate alloc] init];
        [NSUserNotificationCenter defaultUserNotificationCenter].delegate = (id)gDelegate;  // no-pane notification path
        SUUpdater *updater = [SUUpdater sharedUpdater];         // host bundle = this app (SUFeedURL/SUPublicEDKey)
        [updater setDelegate:gDelegate];
        if (gUserInitiated) {
            NSLog(@"[@MAVERICKS_LOG_PREFIX@] user-initiated: starting interactive check");
            [updater checkForUpdates:nil];                     // shows UI (update dialog, or "up-to-date")
        } else {
            NSLog(@"[@MAVERICKS_LOG_PREFIX@] silent probe (watchdog %.0fs)", kBackgroundWatchdogSeconds);
            // Watchdog backstop: force-exit if the probe hangs before any delegate fires. The probe
            // itself shows no UI, so the delegates (found/not-found) resolve quickly and we exit; the
            // watchdog only matters for a network/appcast stall.
            gWatchdog = [NSTimer timerWithTimeInterval:kBackgroundWatchdogSeconds
                                                target:gDelegate selector:@selector(watchdogFired:)
                                              userInfo:nil repeats:NO];
            [[NSRunLoop mainRunLoop] addTimer:gWatchdog forMode:NSRunLoopCommonModes];
            // PROBING check: calls didFindValidUpdate/updaterDidNotFindUpdate but shows NO UI, so a
            // scheduled/unattended run can never leave a blocking dialog up. A found update is surfaced
            // via a notification (no-pane) or the pane hint; the user installs from there.
            [updater checkForUpdateInformation];
        }
        [NSApp run];
    }
    return 0;
}
